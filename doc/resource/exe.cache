                     "log-level-file=detail",
                     "repo1-host=repository",
                     "repo1-host-ca-file=/etc/pgbackrest/cert/ca.crt",
                     "repo1-host-cert-file=/etc/pgbackrest/cert/client.crt",
                     "repo1-host-key-file=/etc/pgbackrest/cert/client.key",
                     "repo1-host-type=tls",
